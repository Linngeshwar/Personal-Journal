@import "tailwindcss";

.ocean{
  --background: #37B7C3 ;
  --secondary-background:#EBF4F6;
  --primary: #088395;
  --secondary: #071952;
    color:black;
}

.purpur{
  --background: #6A1E55;
  --secondary-background:#A64D79;
  --primary: #3B1C32;
  --secondary: #1A1A1D;
    color:white;
} 
@theme inline{
  --color-background: var(--background);
  --color-secondary-bg: var(--secondary-background);
  --color-primary: var(--primary);
  --color-secondary: var(--secondary);
}

@theme{
  --animate-rotateBlue: rotateBlue 0.5s ease-in-out;
  --animate-rotatePurple: rotatePurple 0.5s ease-in-out;
  @keyframes rotateBlue {
  0% {
    transform: rotateX(0deg);
    color: #37B7C3;
  }
  100% {
    transform: rotateX(360deg);
    color: #A64D79;
  } 
}
 @keyframes rotatePurple{
  0% {
    transform: rotateX(0deg);
    color: #A64D79;
  }
  100% {
    transform: rotateX(-360deg);
    color: #37B7C3;
  }
 }
}
  color: white !important;
  border: none !important;
  background: transparent !important;
  padding: 6px 8px !important;
  border-radius: 4px !important;
  transition: all 0.2s ease !important;
}

.react-mde .mde-header-group .mde-header-item button:hover {
  background: var(--color-secondary) !important;
  transform: scale(1.05) !important;
}

.react-mde .mde-tabs button {
  background: transparent !important;
  color: white !important;
  border: none !important;
  padding: 8px 16px !important;
  margin-right: 4px !important;
  border-radius: 6px 6px 0 0 !important;
  transition: all 0.2s ease !important;
}

.react-mde .mde-tabs button.selected {
  background: var(--color-background) !important;
  color: var(--color-secondary) !important;
  font-weight: bold !important;
}

.react-mde .mde-text,
.react-mde .mde-preview {
  background: var(--color-background) !important;
  border: none !important;
  color: inherit !important;
  font-family: inherit !important;
  min-height: 400px !important;
}

.react-mde .mde-text {
  font-size: 14px !important;
  line-height: 1.6 !important;
  resize: none !important;
  padding: 20px !important;
  border-radius: 0 !important;
}

.react-mde .mde-text:focus {
  outline: none !important;
  box-shadow: inset 0 0 0 2px var(--color-secondary) !important;
}

.react-mde .mde-preview {
  padding: 20px !important;
  overflow-y: auto !important;
}

.react-mde .mde-preview h1,
.react-mde .mde-preview h2,
.react-mde .mde-preview h3,
.react-mde .mde-preview h4,
.react-mde .mde-preview h5,
.react-mde .mde-preview h6 {
  color: var(--color-secondary) !important;
  margin-top: 1.5em !important;
  margin-bottom: 0.5em !important;
  font-weight: bold !important;
}

.react-mde .mde-preview h1 {
  font-size: 2rem !important;
  border-bottom: 2px solid var(--color-primary) !important;
  padding-bottom: 0.3em !important;
}

.react-mde .mde-preview h2 {
  font-size: 1.5rem !important;
  border-bottom: 1px solid var(--color-primary) !important;
  padding-bottom: 0.2em !important;
}

.react-mde .mde-preview blockquote {
  border-left: 4px solid var(--color-secondary) !important;
  background: var(--color-secondary-bg) !important;
  margin: 1em 0 !important;
  padding: 0.5em 1em !important;
  border-radius: 0 8px 8px 0 !important;
  font-style: italic !important;
}

.react-mde .mde-preview code {
  background: var(--color-secondary-bg) !important;
  color: var(--color-secondary) !important;
  padding: 0.2em 0.4em !important;
  border-radius: 4px !important;
  font-size: 0.9em !important;
  font-family: "Courier New", monospace !important;
}

.react-mde .mde-preview pre {
  background: var(--color-secondary-bg) !important;
  color: var(--color-secondary) !important;
  padding: 1em !important;
  border-radius: 8px !important;
  overflow-x: auto !important;
  border: 1px solid var(--color-primary) !important;
}

.react-mde .mde-preview pre code {
  background: transparent !important;
  padding: 0 !important;
}

.react-mde .mde-preview table {
  border-collapse: collapse !important;
  width: 100% !important;
  margin: 1em 0 !important;
  border-radius: 8px !important;
  overflow: hidden !important;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1) !important;
}

.react-mde .mde-preview table th,
.react-mde .mde-preview table td {
  border: 1px solid var(--color-primary) !important;
  padding: 0.75em !important;
  text-align: left !important;
}

.react-mde .mde-preview table th {
  background: var(--color-primary) !important;
  color: white !important;
  font-weight: bold !important;
}

.react-mde .mde-preview table tr:nth-child(even) {
  background: var(--color-secondary-bg) !important;
}

.react-mde .mde-preview ul,
.react-mde .mde-preview ol {
  padding-left: 1.5em !important;
  margin: 1em 0 !important;
}

.react-mde .mde-preview li {
  margin: 0.5em 0 !important;
  line-height: 1.6 !important;
}

.react-mde .mde-preview a {
  color: var(--color-secondary) !important;
  text-decoration: none !important;
  border-bottom: 1px solid var(--color-secondary) !important;
  transition: all 0.2s ease !important;
}

.react-mde .mde-preview a:hover {
  background: var(--color-secondary-bg) !important;
  padding: 0 2px !important;
}

/* Utility classes */
.line-clamp-1 {
  display: -webkit-box !important;
  -webkit-line-clamp: 1 !important;
  line-clamp: 1 !important;
  -webkit-box-orient: vertical !important;
  overflow: hidden !important;
}

.line-clamp-2 {
  display: -webkit-box !important;
  -webkit-line-clamp: 2 !important;
  line-clamp: 2 !important;
  -webkit-box-orient: vertical !important;
  overflow: hidden !important;
}

/* Theme colors */
.ocean {
  --background: #37b7c3;
  --secondary-background: #ebf4f6;
  --primary: #088395;
  --secondary: #071952;
  color: black;
}

.purpur {
  --background: #6a1e55;
  --secondary-background: #a64d79;
  --primary: #3b1c32;
  --secondary: #1a1a1d;
  color: white;
}

:root {
  --color-background: var(--background);
  --color-secondary-bg: var(--secondary-background);
  --color-primary: var(--primary);
  --color-secondary: var(--secondary);
}

/* Animations */
@keyframes rotateBlue {
  0% {
    transform: rotateX(0deg);
    color: #37b7c3;
  }
  100% {
    transform: rotateX(360deg);
    color: #a64d79;
  }
}

@keyframes rotatePurple {
  0% {
    transform: rotateX(0deg);
    color: #a64d79;
  }
  100% {
    transform: rotateX(-360deg);
    color: #37b7c3;
  }
}

.animate-rotateBlue {
  animation: rotateBlue 0.5s ease-in-out;
}

.animate-rotatePurple {
  animation: rotatePurple 0.5s ease-in-out;
}
